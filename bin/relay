#!/bin/bash
# relay - launch the iTerm2-native Relay control panel, or run a swarm verb.
#
#   relay            run the TUI (watches iTerm2, auto-clears safe prompts in
#                    ARMED sessions, pings you on dangerous ones, delivers
#                    swarm messages into idle sessions)
#   relay --dry-run  watch + notify but NEVER inject (safe first run)
#   relay register|send|status|task|inbox|msgs|spawn|doctor|clean|restore|wipe ...
#                    swarm CLI verbs (see: relay register -h etc.)
#   relay demo       guided 60s tour: spawns a demo worker, you watch the loop
#   relay doctor     print swarm health from outside the TUI (debugging)
#   relay update     fetch + fast-forward to the latest relay version
#                    (the TUI also self-updates at start, at most once a day;
#                    disable with RELAY_NO_AUTOUPDATE=1)
#   relay -h         this help
#
# One process: tool on === TUI open; quit (q) === everything stops. No daemon,
# no auto-launch, no Claude Code hooks. Safety classifier is lib/danger.sh.
#
# Requires: macOS, iTerm2 with Python API enabled, python3 with `iterm2` and
# `textual` installed (pip install iterm2 textual).
set -e
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
case "${1:-}" in
  -h|--help) sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
  register|send|status|task|inbox|msgs|spawn|doctor|demo|version|update|clean|restore|wipe)
    exec python3 "$HERE/../iterm/cli.py" "$@" ;;
esac
# TUI start: quiet self-update BEFORE the app boots, so the code that runs is
# current and any DB migration applies on this same launch. Throttled to once
# a day, silent when offline/dirty/current, never blocks a launch on failure.
# Skipped for dry-run in EVERY spelling app.py accepts (--dry-run/--dryrun/-n,
# any position) - dry-run mutates nothing, including the checkout.
DRY=0
for a in "$@"; do
  case "$a" in
    --dry-run|--dryrun|-n) DRY=1 ;;
  esac
done
if [ "$DRY" = 0 ]; then
  python3 "$HERE/../iterm/cli.py" update --auto || true
fi
exec python3 "$HERE/../iterm/app.py" "$@"
